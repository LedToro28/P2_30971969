<!-- Barra de Navegación Principal -->
<nav class="navbar navbar-expand-lg navbar-custom">
    <div class="container-fluid">
        <!-- Marca de tu aplicación -->
        <a class="navbar-brand" href="/">Ciclexpress</a>

        <!-- Botón para Offcanvas en pantallas pequeñas -->
        <button class="navbar-toggler d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasExample" aria-controls="offcanvasExample">
            <i class="fa-solid fa-bars"></i> <!-- Icono de menú para móvil -->
        </button>

        <!-- Contenido de la barra de navegación para escritorio -->
        <div class="d-none d-lg-flex" id="navbarNavDesktop">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" aria-current="page" href="/"><i class="fa-solid fa-house-chimney"></i> Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/informacion"><i class="fa-solid fa-circle-info"></i> Información</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/servicios"><i class="fa-solid fa-server"></i> Servicios</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/contacto"><i class="fa-solid fa-address-book"></i> Contáctanos</a>
                </li>
                <!-- Enlaces de administración, solo si el usuario está autenticado -->
                <% if (locals.currentUser) { %>
                <li class="nav-item">
                    <a class="nav-link" href="/admin/contacts"><i class="fa-solid fa-address-card"></i> Tabla-Contactos</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/admin/payments"><i class="fa-solid fa-money-bill-transfer"></i> Pagos</a>
                </li>
                <% } %>
            </ul>
        </div>
        
        <!-- Botones de login/logout y registro -->
        <div class="d-flex align-items-center ms-auto">
            <% if (locals.currentUser) { %>
                <span class="navbar-text me-3 text-white">
                    Hola, <%= locals.currentUser.display_name || locals.currentUser.username %>
                </span>
                <a href="/logout" class="btn btn-outline-light btn-sm">Salir</a>
            <% } else { %>
                <a href="/login" class="btn btn-outline-light btn-sm me-2">Iniciar Sesión</a>
                <a href="/register" class="btn btn-primary btn-sm">Registrarse</a>
            <% } %>
        </div>
    </div>
</nav>

<!-- Offcanvas (Menú Lateral para Móviles) -->
<div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasExample" aria-labelledby="offcanvasExampleLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="offcanvasExampleLabel">Menú Principal</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" aria-current="page" href="/"><i class="fa-solid fa-house-chimney"></i> Home</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/informacion"><i class="fa-solid fa-circle-info"></i> Información</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/servicios"><i class="fa-solid fa-server"></i> Servicios</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/contacto"><i class="fa-solid fa-address-book"></i> Contáctanos</a>
            </li>
            <!-- Enlaces de administración en el offcanvas -->
            <% if (locals.currentUser) { %>
            <li class="nav-item">
                <a class="nav-link" href="/admin/contacts"><i class="fa-solid fa-address-card"></i> Tabla-Contactos</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/admin/payments"><i class="fa-solid fa-money-bill-transfer"></i> Pagos</a>
            </li>
            <% } %>
            <!-- Opciones de autenticación en el offcanvas -->
            <li class="nav-item mt-3">
                <% if (locals.currentUser) { %>
                    <a href="/logout" class="btn btn-outline-secondary w-100"><i class="fa-solid fa-right-from-bracket"></i> Salir</a>
                <% } else { %>
                    <a href="/login" class="btn btn-outline-primary w-100 mb-2"><i class="fa-solid fa-right-to-bracket"></i> Iniciar Sesión</a>
                    <a href="/register" class="btn btn-primary w-100"><i class="fa-solid fa-user-plus"></i> Registrarse</a>
                <% } %>
            </li>
        </ul>
    </div>
</div>
